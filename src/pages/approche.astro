---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import courseuse from '../assets/images/approche-strategique-performance-femme-endurance.webp';
import cycliste from '../assets/images/approche-analyse-terrain-femme-endurance.webp';
import iconHormonal from '../assets/images/equilibre-hormonal-femme.webp';
import iconAlimentation from '../assets/images/alimentation-equilibree-sport.webp';
import iconMicronutrition from '../assets/images/analyse-statut-micronutriments.webp';
import iconSommeil from '../assets/images/icon-sommeil.webp';
import iconStress from '../assets/images/icon-stress.webp';
import iconEntrainement from '../assets/images/icon-entrainement.webp';
---

<Layout title="Approche" description="Une approche stratégique et physiologique de la performance féminine en endurance.">

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Une approche stratégique et physiologique de la performance féminine</h1>
    </div>
  </section>

  <!-- Ce que cette approche n'est pas -->
  <section class="not-section">
    <div class="not-container">
      <div class="not-content">
        <div class="not-card">
          <h2>Ce que cette approche n'est pas</h2>
          <p>
            Mon approche ne repose pas sur des recettes universelles ou des protocoles standardisés.
          </p>
          <p>
            Elle ne consiste pas à faire "toujours plus" :
          </p>
          <ul class="cross-list">
            <li>plus d'entraînement</li>
            <li>plus de discipline</li>
            <li>plus de contraintes</li>
            <li>ni à masquer les signaux du corps pour continuer à avancer coûte que coûte.</li>
          </ul>
          <p>
            Dans le sport d'endurance, beaucoup de femmes font déjà énormément de choses "comme il faut".
          </p>
          <p class="text-gold highlight-text">
            Quand les résultats ne suivent plus, le problème n'est généralement pas un manque de volonté, mais un déséquilibre plus profond que le corps compense en silence.
          </p>
        </div>
      </div>
      <div class="not-image">
        <Image
          src={courseuse}
          alt="Coureuse en pleine nature"
          width={934}
          height={700}
        />
      </div>
    </div>
  </section>

  <!-- Quand le corps compense -->
  <section class="section compensate-section">
    <div class="container">
      <h2 class="section-title">Quand le corps compense au lieu de s'adapter</h2>
      <div class="content-centered">
        <p>
          La performance durable repose sur une capacité clé : <strong>l'adaptation</strong>.
        </p>
        <p>
          Or, chez les femmes sportives d'endurance, cette adaptation peut être freinée par des facteurs souvent sous-estimés :
        </p>
        <ul class="dot-list">
          <li>Charge d'entraînement</li>
          <li>Récupération incomplète</li>
          <li>Apports nutritionnels déséquilibrés</li>
          <li>Fluctuations hormonales</li>
          <li>Stress émotionnel</li>
          <li>Contraintes de la vie quotidienne&hellip;</li>
        </ul>
        <p>
          Lorsque ces paramètres s'additionnent, le corps ne s'adapte plus réellement. Il compense. La compensation permet de tenir un temps, mais elle se fait toujours au détriment de quelque chose : l'énergie, la motivation, la stabilité hormonale, les capacités de réparation ou la progression à long terme.
        </p>
        <p class="text-gold highlight-text">
          Mon travail commence précisément là où la compensation s'installe.
        </p>
      </div>
    </div>
  </section>

  <!-- Comprendre avant d'agir -->
  <section class="understand-section">
    <div class="understand-container">
      <div class="understand-image">
        <Image
          src={cycliste}
          alt="Cycliste femme en VTT montagne"
          width={934}
          height={700}
        />
      </div>
      <div class="understand-content">
        <div class="understand-card">
          <h2>Comprendre avant d'agir</h2>
          <p>
            Accompagner la performance, c'est d'abord comprendre comment le corps fonctionne dans un contexte précis, à un moment donné.
          </p>
          <p>
            Chaque femme, chaque parcours sportif, chaque histoire physiologique est différente.
          </p>
          <p>
            C'est pourquoi mon approche repose sur une analyse fine du fonctionnement du terrain physiologique avant toute recommandation.
          </p>
          <p>Comprendre :</p>
          <ul class="dot-list">
            <li>ce que le corps est capable d'assimiler</li>
            <li>ce qu'il compense déjà</li>
            <li>ce qui freine réellement l'adaptation</li>
          </ul>
          <p>
            permet ensuite d'agir de manière ciblée, progressive et respectueuse de l'équilibre global.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- De la compréhension à l'action -->
  <section class="section action-section">
    <div class="container">
      <h2 class="section-title">De la compréhension à l'action</h2>
      <div class="content-centered">
        <p>
          Comprendre le fonctionnement du corps n'est jamais une fin en soi.
        </p>
        <p>
          Cette compréhension permet ensuite de mettre en place des actions ciblées, adaptées à ce que le corps est réellement capable d'assimiler à un moment donné.
        </p>
        <p>
          Concrètement, l'accompagnement vise à soutenir les fonctions qui conditionnent directement la progression en endurance :
        </p>
        <ul class="dot-list">
          <li>Maintenir une énergie stable au quotidien et à l'entraînement</li>
          <li>Améliorer la qualité de récupération entre les séances</li>
          <li>Stabiliser l'équilibre hormonal et nerveux</li>
          <li>Augmenter la capacité à encaisser la charge d'entraînement sans fragiliser le corps</li>
        </ul>
        <blockquote>
          <strong>Objectif :</strong> restaurer une capacité d'adaptation efficace pour que l'entraînement produise enfin les effets attendus, sans épuiser le système.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Les leviers -->
  <section class="section levers-section">
    <div class="container">
      <h2 class="section-title">Les leviers de la performance féminine en endurance</h2>
      <p class="section-subtitle">
        La performance féminine ne dépend pas d'un seul facteur. Elle repose sur plusieurs leviers qui déterminent la capacité à progresser en endurance.
      </p>
      <div class="levers-grid">
        <div class="lever-card">
          <Image src={iconHormonal} alt="Équilibre hormonal" width={80} height={80} />
          <h3>Équilibre hormonal</h3>
        </div>
        <div class="lever-card">
          <Image src={iconAlimentation} alt="Alimentation équilibrée" width={80} height={80} />
          <h3>Alimentation équilibrée</h3>
        </div>
        <div class="lever-card">
          <Image src={iconMicronutrition} alt="Statut en micronutriments clés" width={80} height={80} />
          <h3>Statut en micronutriments clés</h3>
        </div>
        <div class="lever-card">
          <Image src={iconSommeil} alt="Qualité de la récupération" width={80} height={80} />
          <h3>Qualité de la récupération</h3>
        </div>
        <div class="lever-card">
          <Image src={iconStress} alt="Gestion du stress et de la charge mentale" width={80} height={80} />
          <h3>Gestion du stress et de la charge mentale</h3>
        </div>
        <div class="lever-card">
          <Image src={iconEntrainement} alt="Tolérance à la charge d'entraînement" width={80} height={80} />
          <h3>Tolérance à la charge d'entraînement</h3>
        </div>
      </div>
      <p class="section-note">
        Au cours de l'accompagnement, ces leviers sont ajustés de manière ciblée en nutrition, micronutrition et hygiène de vie, afin que l'entraînement redevienne un moteur de progression, et non une source d'épuisement.
      </p>
    </div>
  </section>

  <!-- Protocole PERFORM -->
  <section class="section perform-section">
    <div class="container">
      <h2 class="section-title">Le Protocole PERFORM</h2>
      <div class="content-centered">
        <p>
          Pour structurer cette démarche, j'ai développé un cadre de travail que j'ai nommé <strong>Protocole PERFORM</strong>.
        </p>
        <p>
          Il ne s'agit pas d'un protocole figé ni d'une succession d'étapes identiques pour toutes, mais d'un cadre d'analyse et d'ajustement pensé spécifiquement pour les femmes sportives d'endurance.
        </p>
        <p>PERFORM permet de :</p>
        <ul class="dot-list">
          <li>Hiérarchiser les leviers réellement pertinents</li>
          <li>Éviter l'empilement de conseils inutiles</li>
          <li>Ajuster les recommandations dans le temps, en fonction des réponses du corps</li>
        </ul>
        <p>
          Ce cadre me permet de rester cohérente, structurée et adaptable, tout en respectant la singularité de chaque femme accompagnée.
        </p>
      </div>
      </div>
    </div>
  </section>

  <!-- FAQ Physiologie féminine -->
  <section class="section faq-section">
    <div class="container">
      <div class="faq-accompagnement">
        <h2 class="section-title">Questions fréquentes sur la performance féminine en endurance</h2>

        <div class="faq-item">
          <div class="faq-header">
            <h3>Faut-il adapter son entraînement quand on est une femme ?</h3>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="faq-body">
            <div class="faq-body-inner">
              <p>Les principes fondamentaux de l'entraînement — progressivité, surcharge adaptée, récupération — sont universels. En revanche, certains paramètres physiologiques spécifiques aux femmes peuvent influencer la manière dont l'organisme s'adapte à l'effort.</p>
              <p>Les fluctuations hormonales au cours du cycle menstruel peuvent moduler la récupération, la thermorégulation ou la perception de l'effort, avec une variabilité importante d'une femme à l'autre. De plus, la disponibilité énergétique, le statut en fer ou les contraintes de vie peuvent avoir un impact plus marqué chez la sportive d'endurance.</p>
              <p>Il ne s'agit donc pas d'entraîner « différemment » par principe, mais d'intégrer ces paramètres pour ajuster intelligemment la charge et soutenir une progression durable.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-header">
            <h3>Le cycle menstruel impacte-t-il réellement la performance en endurance ?</h3>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="faq-body">
            <div class="faq-body-inner">
              <p>Le cycle menstruel influence la physiologie et peut moduler certaines capacités. Les variations d'œstrogènes et de progestérone influencent la thermorégulation, l'utilisation des substrats énergétiques, la récupération et parfois la perception de l'effort. Certaines phases peuvent être plus favorables à l'intensité, d'autres à l'endurance ou au travail technique.</p>
              <p>Cependant, l'impact varie fortement d'une femme à l'autre. Un cycle stable et bien régulé n'entraîne pas nécessairement de baisse de performance.</p>
              <p>L'objectif n'est pas de subir ces variations, mais de les comprendre pour ajuster intelligemment l'entraînement et la récupération.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-header">
            <h3>Est-il normal de rester fatiguée malgré un entraînement structuré ?</h3>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="faq-body">
            <div class="faq-body-inner">
              <p>Une fatigue transitoire après une période d'entraînement soutenue est normale : elle fait partie du processus d'adaptation. En revanche, une fatigue qui persiste malgré un programme structuré et des phases de récupération adaptées mérite d'être analysée.</p>
              <p>Chez la sportive d'endurance, cette fatigue peut traduire un déséquilibre entre la charge d'entraînement et la capacité réelle d'adaptation de l'organisme. Disponibilité énergétique insuffisante, statut micronutritionnel limite, fluctuations hormonales, qualité du sommeil ou contraintes de vie peuvent interagir et freiner la récupération.</p>
              <p>Dans ce contexte, augmenter simplement le repos ou modifier l'entraînement au hasard ne suffit pas toujours. L'enjeu est d'identifier les leviers prioritaires afin de restaurer une dynamique cohérente et durable, compatible avec la santé et la performance.</p>
            </div>
          </div>
        </div>

      </div>
      <p class="faq-cta-text">Tu te reconnais dans ces situations ? Parlons-en.</p>
      <div class="text-center">
        <a href="https://calendly.com/marlenepetit/appel-clarification" class="btn btn-on-sage" target="_blank" rel="noopener">
          Réserver un appel
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Page Header */
  .page-header {
    background-color: var(--color-sage);
    padding: 64px 24px 20px;              /* === AJUSTE : espacement haut / côtés / bas === */
    text-align: center;
  }

  .page-header h1 {
    max-width: 700px;
    margin: 0px auto -20px;                 /* === AJUSTE : marge haut / auto côtés / bas du H1 === */
    font-size: 32px;                      /* === AJUSTE : taille titre H1 === */
    color: var(--color-white);
  }

  /* ============================================================
     SECTION "Ce que cette approche n'est pas" — SKILL IMAGE+TEXTE
     ============================================================ */

  .not-section {
    background-color: var(--color-sage);
    padding: 40px 0 90px;                      /* === AJUSTE : espacement haut / bas === */
    overflow: hidden;
  }

  .not-container {
    max-width: 1200px;                        /* === AJUSTE : largeur max === */
    margin: 0 auto;
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 0;
    align-items: center;
    padding: 0 50px;                          /* === AJUSTE : marge gauche/droite === */
  }

  .not-content {
    position: relative;
    padding-right: 32px;
  }

  .not-card {
    background-color: var(--color-white);
    margin: 20px;                             /* === AJUSTE : marge autour de la carte === */
    padding: 50px;                            /* === AJUSTE : espacement intérieur === */
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);  /* === AJUSTE : ombre de la carte === */
  }

  .not-card h2 {
    color: var(--color-green-dark);
    text-align: center;
    letter-spacing: 0px;
    margin-bottom: 24px;                          /* === AJUSTE : espace sous H2 carte === */
  }

  .not-card p,
  .not-card ul {
    text-align: left;
  }

  .not-card p {
    font-family: 'Nunito', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #475467;
    line-height: 1.6;
    margin-bottom: 16px;                      /* === AJUSTE : espace sous paragraphe === */
  }

  .not-card p.text-gold {
    color: var(--color-gold);
  }

  .not-image {
    display: flex;
    justify-content: start;
    align-items: center;
    margin-top: -53px;                        /* === AJUSTE : décalage haut === */
    margin-right: -53px;                      /* === AJUSTE : décalage droite === */
    margin-bottom: -53px;                     /* === AJUSTE : décalage bas === */
    margin-left: -120px;                      /* === AJUSTE : chevauchement carte === */
    z-index: 0;
    position: relative;
  }

  .not-image img {
    width: 70%;                               /* === AJUSTE : largeur de l'image === */
    max-width: 420px;                         /* === AJUSTE : largeur max === */
    max-height: 500px;                        /* === AJUSTE : hauteur max === */
    height: auto;
    object-fit: cover;
    object-position: center 25%;           /* === AJUSTE : cadrage (0%=haut, 25%=haut-centre, 50%=centre, 100%=bas) === */
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);  /* === AJUSTE : ombre de la photo === */
  }

  .cross-list {
    list-style: none;
    margin-bottom: 16px;
  }

  .cross-list li {
    position: relative;
    padding-left: 28px;
    margin-bottom: 6px;
    font-size: 16px;
    color: #475467;
    line-height: 1.6;
  }

  .cross-list li::before {
    content: '\2716';
    position: absolute;
    left: 0;
    color: #e74c3c;
    font-weight: 700;
  }

  /* Compensate */
  .compensate-section {
    background-color: var(--color-white);
  }

  .content-centered {
    max-width: 750px;
    margin: 0 auto;
  }

  .dot-list {
    list-style: none;
    margin-bottom: 24px;
    padding-left: 0;
  }

  .dot-list li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 8px;
  }

  .dot-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 8px;
    background-color: var(--color-gold);
    border-radius: 50%;
  }

  .highlight-text {
    font-size: 18px;
    font-weight: 600;
    font-style: italic;
    margin-top: 16px;
  }

  .highlight-box {
    background-color: var(--color-bg);
    padding: 20px 24px;
    border-left: 4px solid var(--color-gold);
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    margin-top: 24px;
  }

  /* ============================================================
     SECTION "Comprendre avant d'agir" — SKILL IMAGE+TEXTE
     Image à gauche, texte à droite
     ============================================================ */

  .understand-section {
    background-color: var(--color-sage);
    padding: 90px 0;                          /* === AJUSTE : espacement haut/bas === */
    overflow: hidden;
  }

  .understand-container {
    max-width: 1200px;                        /* === AJUSTE : largeur max === */
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 3fr;           /* image à gauche, texte à droite */
    gap: 0;
    align-items: center;
    padding: 0 50px;                          /* === AJUSTE : marge gauche/droite === */
  }

  .understand-content {
    position: relative;
    padding-left: 32px;
  }

  .understand-card {
    background-color: var(--color-white);
    margin: 20px;                             /* === AJUSTE : marge autour de la carte === */
    padding: 50px;                            /* === AJUSTE : espacement intérieur === */
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);  /* === AJUSTE : ombre de la carte === */
  }

  .understand-card h2 {
    color: var(--color-green-dark);
    text-align: center;
    letter-spacing: 0px;
    margin-bottom: 24px;                          /* === AJUSTE : espace sous H2 carte === */
  }

  .understand-card p,
  .understand-card ul {
    text-align: left;
  }

  .understand-card p {
    font-family: 'Nunito', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #475467;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .understand-image {
    display: flex;
    justify-content: end;
    align-items: center;
    margin-top: -53px;                        /* === AJUSTE : décalage haut === */
    margin-left: -53px;                       /* === AJUSTE : décalage gauche === */
    margin-bottom: -53px;                     /* === AJUSTE : décalage bas === */
    margin-right: -120px;                     /* === AJUSTE : chevauchement carte === */
    z-index: 0;
    position: relative;
  }

  .understand-image img {
    width: 70%;                               /* === AJUSTE : largeur de l'image === */
    max-width: 420px;                         /* === AJUSTE : largeur max === */
    max-height: 500px;                        /* === AJUSTE : hauteur max === */
    height: auto;
    object-fit: cover;
    object-position: center center;           /* === AJUSTE : cadrage === */
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);  /* === AJUSTE : ombre de la photo === */
  }

  .understand-card .dot-list li {
    font-size: 16px;
    color: #475467;
    line-height: 1.6;
  }

  .understand-card .dot-list li::before {
    background-color: var(--color-gold);
  }

  /* Action */
  .action-section {
    background-color: var(--color-white);
  }

  .action-section blockquote {
    border-left: 4px solid var(--color-gold);
    background-color: rgba(192, 161, 88, 0.08);
    padding: 24px 32px;                          /* === AJUSTE : espacement intérieur citation === */
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    font-style: italic;
    color: var(--color-heading);
    font-size: 16px;
    line-height: 1.6;
    margin-top: 24px;                            /* === AJUSTE : espace au-dessus de la citation === */
  }

  /* Levers */
  .levers-section {
    background-color: var(--color-sage);            /* === AJUSTE : fond vert sauge === */
    color: #2a2a2a;                                 /* === AJUSTE : couleur texte sur fond sauge === */
  }

  .levers-section .section-title {
    color: #2a2a2a;                                 /* === AJUSTE : couleur titre sur fond sauge === */
  }

  .levers-section .section-subtitle {
    color: #2a2a2a;                                 /* === AJUSTE : couleur sous-titre sur fond sauge === */
  }

  .levers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .lever-card {
    background-color: var(--color-white);
    padding: 32px 24px;                              /* === AJUSTE : espacement intérieur carte === */
    border-radius: var(--border-radius);
    text-align: center;
    border: 1px solid var(--color-gold);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    transition: var(--transition);
  }

  .lever-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .lever-card img {
    margin: 0 auto 12px;                             /* === AJUSTE : espace sous l'icône === */
    border-radius: 50%;
  }

  .lever-card h3 {
    font-size: 16px;                                  /* === AJUSTE : taille texte levier === */
    font-weight: 600;
    color: var(--color-heading);
    margin: 0;
    line-height: 1.5;
  }

  .section-note {
    max-width: 750px;
    margin: 0 auto;
    text-align: center;
    color: #2a2a2a;                                 /* === AJUSTE : couleur note sur fond sauge === */
    font-size: 15px;
  }

  /* Perform */
  .perform-section {
    background-color: var(--color-white);
  }

  /* Responsive — Tablette */
  @media (max-width: 1024px) {
    .not-section,
    .understand-section {
      padding: 0;
    }

    .not-container,
    .understand-container {
      grid-template-columns: 1fr;
      padding: 50px 40px 65px;
    }

    .not-content,
    .understand-content {
      padding-right: 0;
      padding-left: 0;
    }

    .not-image,
    .understand-image {
      order: -1;                              /* === image au-dessus de la carte dès tablette === */
      justify-content: center;
      margin-top: -30px;                      /* === AJUSTE TABLETTE : marge haut === */
