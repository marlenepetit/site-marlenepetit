<script>
  document.querySelectorAll('.faq-header').forEach(function(header) {
    header.addEventListener('click', function() {
      var item = this.closest('.faq-item');
      var isOpen = item.classList.contains('open');

      /* Ferme tous les items ouverts */
      document.querySelectorAll('.faq-item.open').forEach(function(el) {
        el.querySelector('.faq-body').style.setProperty('--body-height', '0px');
        el.classList.remove('open');
      });

      /* Ouvre l'item cliqué s'il n'était pas déjà ouvert */
      if (!isOpen) {
        var body = item.querySelector('.faq-body');
        var inner = item.querySelector('.faq-body-inner');
        var h = inner.scrollHeight + 10;
        body.style.setProperty('--body-height', h + 'px');
        item.classList.add('open');
      }
    });
  });
</script>
