---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contactez Marlène Petit - Naturopathe micronutritionniste à Dijon et en ligne. Consultation en cabinet ou à distance en visio.">

  <!-- Message de succès (affiché par JS si ?success=true) -->
  <div class="success-banner" id="success-banner" style="display:none;">
    <div class="container success-inner">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
      <p>Merci pour votre message ! Je vous répondrai dans les plus brefs délais.</p>
      <button class="success-close" onclick="document.getElementById('success-banner').remove()" aria-label="Fermer">✕</button>
    </div>
  </div>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Un doute, une question, besoin d'informations supplémentaires ?</h1>
      <p class="page-intro">
        N'hésitez pas à me poser vos questions, j'y répondrai personnellement dans les plus brefs délais.
      </p>
    </div>
  </section>

  <!-- Consultation formats -->
  <section class="section formats-section">
    <div class="container">
      <h2 class="section-title">Accompagnement</h2>
      <div class="formats-grid">
        <div class="format-card">
          <div class="format-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h3>À Dijon</h3>
          <p>au sein de mon cabinet</p>
          <a href="#adresse" class="btn btn-on-sage">Voir l'adresse</a>
        </div>
        <div class="format-card">
          <div class="format-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <h3>À Distance</h3>
          <p>en visio</p>
          <a href="#contact-form" class="btn btn-on-sage">Me contacter</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="section info-section">
    <div class="container">
      <div class="info-grid">
        <div class="info-item">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <h3>Téléphone</h3>
          <a href="tel:+33744806714">07 44 80 67 14</a>
          <a href="https://wa.me/33744806714" target="_blank" rel="noopener" class="whatsapp-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Contacter via WhatsApp
          </a>
        </div>
        <div class="info-item">
          <div class="info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <h3>Email</h3>
          <a href="mailto:contact@marlenepetit.fr">contact@marlenepetit.fr</a>
        </div>
        <div class="info-item">
          <div class="info-icon" id="adresse">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h3>Adresse</h3>
          <a href="https://maps.google.com/?q=30+rue+René+Cassin+21000+Dijon" target="_blank" rel="noopener">30 rue René Cassin<br />21000 Dijon</a>
        </div>
      </div>
      <div class="text-center" style="margin-top: 2rem;">
        <a href="https://calendly.com/marlenepetit/appel-clarification" class="btn" target="_blank" rel="noopener">
          Réserver un appel
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section form-section" id="contact-form">
    <div class="container">
      <h2 class="section-title">Formulaire de contact</h2>
      <form class="contact-form" action="https://formsubmit.co/contact@marlenepetit.fr" method="POST">
        <input type="hidden" name="_subject" value="Nouveau message depuis le site" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://marlenepetit.fr/contact?success=true" />
        <input type="text" name="_honey" style="display:none" />

        <div class="form-row">
          <div class="form-group">
            <label for="nom">Nom</label>
            <input type="text" id="nom" name="nom" required />
          </div>
          <div class="form-group">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" name="prenom" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>
        <div class="text-center">
          <button type="submit" class="btn btn-on-sage">Envoyer</button>
        </div>
      </form>
    </div>
  </section>

</Layout>

<style>
  /* Bandeau de succès */
  .success-banner {
    background-color: #f0ead2;                          /* === AJUSTE : fond bandeau succès === */
    border-bottom: 3px solid var(--color-gold);         /* === AJUSTE : bordure bas bandeau === */
    padding: 16px 20px;                                 /* === AJUSTE : padding bandeau === */
  }

  .success-inner {
    display: flex;
    align-items: center;
    gap: 12px;                                          /* === AJUSTE : espace icône → texte === */
    max-width: 700px;
    margin: 0 auto;
  }

  .success-inner svg {
    color: var(--color-sage-dark, #3c571d);
    flex-shrink: 0;
  }

  .success-inner p {
    margin: 0;
    font-size: 15px;                                    /* === AJUSTE : taille texte succès === */
    color: var(--color-heading);
    font-weight: 600;
  }

  .success-close {
    background: none;
    border: none;
    font-size: 18px;                                    /* === AJUSTE : taille bouton fermer === */
    cursor: pointer;
    color: var(--color-text-light);
    margin-left: auto;
    padding: 4px 8px;
    line-height: 1;
    transition: var(--transition);
  }

  .success-close:hover {
    color: var(--color-heading);
  }

  /* Page Header */
  .page-header {
    background-color: var(--color-white);
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: 1.85rem;
    max-width: 650px;
    margin: 0 auto 1rem;
  }

  .page-intro {
    color: var(--color-text-light);
    max-width: 550px;
    margin: 0 auto;
  }

  /* Formats */
  .formats-section {
    background-color: var(--color-sage);            /* === AJUSTE : fond vert sauge === */
  }

  .formats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .format-card {
    background-color: var(--color-white);
    padding: 2.5rem 2rem;
    border-radius: var(--border-radius);
    text-align: center;
    border: 1px solid var(--color-gold);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);    /* === AJUSTE : ombre carte === */
    transition: var(--transition);
  }

  .format-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);    /* === AJUSTE : ombre hover carte === */
  }

  .format-icon {
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .format-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.25rem;
  }

  .format-card p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  /* Info */
  .info-section {
    background-color: var(--color-white);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .info-item {
    text-align: center;
  }

  .info-icon {
    color: var(--color-gold);
    margin-bottom: 4px;                             /* === AJUSTE : espace icône → titre === */
    scroll-margin-top: 80px;                        /* === AJUSTE : marge pour le menu fixe === */
  }

  .info-item h3 {
    font-size: 1rem;
    margin-bottom: 2px;                             /* === AJUSTE : espace titre → lien === */
  }

  .info-item a {
    font-size: 0.95rem;
  }

  .whatsapp-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;                                       /* === AJUSTE : espace icône → texte === */
    margin-top: 6px;                                /* === AJUSTE : espace au-dessus du lien WhatsApp === */
    font-size: 14px;                                /* === AJUSTE : taille texte WhatsApp === */
  }

  .info-item p {
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0;
  }

  /* Form */
  .form-section {
    background-color: var(--color-sage);            /* === AJUSTE : fond vert sauge === */
  }

  .contact-form {
    max-width: 650px;
    margin: 0 auto;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 0.4rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-family: var(--font-family);
    font-size: 0.95rem;
    color: var(--color-heading);
    background-color: var(--color-white);
    transition: var(--transition);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(192, 161, 88, 0.15);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .formats-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('success-banner')?.style.setProperty('display', 'block');
  }
</script>
