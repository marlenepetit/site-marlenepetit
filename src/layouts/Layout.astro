---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWidget from '../components/FloatingWidget.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = "Stratège de la performance et de la santé féminine - J'aide les femmes sportives d'endurance à performer avec leur corps, pas contre lui.", noindex = false } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Marlène Petit</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingWidget />
  </body>
</html>
