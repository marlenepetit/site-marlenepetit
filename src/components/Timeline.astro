---
/* Composant Timeline Accordéon — Parcours professionnel */
---

<div class="tl-container">

  <!-- ─── ÈRE 1 : RECHERCHE SCIENTIFIQUE ─── -->
  <div class="tl-era-group era-science-group">
    <span class="tl-era-label">Recherche scientifique<span class="tl-era-dates"> · 2007–2023</span></span>

    <!-- Doctorat -->
    <div class="tl-item era-science-item">
      <div class="tl-spine">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/></svg>
        </div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-content">
        <div class="tl-header">
          <div class="tl-meta">
            <span class="tl-period">2007 — 2010</span>
            <span class="tl-title">Doctorat de Physique</span>
          </div>
          <svg class="tl-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="5 8 10 13 15 8"/>
          </svg>
        </div>
        <div class="tl-body">
          <div class="tl-body-inner">
            <p>3 ans de recherche fondamentale en physique au Commissariat à l'Énergie Atomique (CEA Grenoble).</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CNRS -->
    <div class="tl-item era-science-item">
      <div class="tl-spine">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/></svg>
        </div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-content">
        <div class="tl-header">
          <div class="tl-meta">
            <span class="tl-period">2012 — 2023</span>
            <span class="tl-title">Ingénieure CNRS</span>
          </div>
          <svg class="tl-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="5 8 10 13 15 8"/>
          </svg>
        </div>
        <div class="tl-body">
          <div class="tl-body-inner">
            <p>11 ans au sein du Centre National de la Recherche Scientifique, à mener des travaux de recherche appliquée, d'ingénierie expérimentale et de publication scientifique.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── ÈRE 2 : ÉVOLUTION PROFESSIONNELLE ─── -->
  <div class="tl-era-group era-transition-group">
    <span class="tl-era-label">Évolution professionnelle<span class="tl-era-dates"> · 2019–2024</span></span>

    <!-- Naturopathie -->
    <div class="tl-item era-transition-item">
      <div class="tl-spine">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/></svg>
        </div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-content">
        <div class="tl-header">
          <div class="tl-meta">
            <span class="tl-period">2019</span>
            <span class="tl-title">Diplôme de Naturopathie</span>
          </div>
          <svg class="tl-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="5 8 10 13 15 8"/>
          </svg>
        </div>
        <div class="tl-body">
          <div class="tl-body-inner">
            <p>Diplôme certifié par la <a href="https://lafena.fr/" target="_blank">Fédération Française de Naturopathie</a> (FÉNA).<br>Formation de référence nationale en approche globale et intégrative de la santé : <a href="https://vitalopathie.fr/" target="_blank">Académie de vitalopathie</a>
</p>
            <div class="tl-divider"></div>
            <div class="tl-section-label">Spécialités</div>
            <div class="tl-tags">
              <span class="tl-tag tag-sage">Phytothérapie</span>
              <span class="tl-tag tag-sage">Aromathérapie</span>
              <span class="tl-tag tag-sage">Gemmothérapie</span>
              <span class="tl-tag tag-sage">Chronobiologie</span>
              <span class="tl-tag tag-sage">Gestion du stress</span>
              <span class="tl-tag tag-sage">Hygiène de vie</span>
              <span class="tl-tag tag-sage">Alimentation santé</span>
              <span class="tl-tag tag-sage">Micronutrition</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Micronutrition SIIN -->
    <div class="tl-item era-transition-item">
      <div class="tl-spine">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5"/></svg>
        </div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-content">
        <div class="tl-header">
          <div class="tl-meta">
            <span class="tl-period">2019 — 2024</span>
            <span class="tl-title">D.I. Nutrition Santé & Micronutrition</span>
          </div>
          <svg class="tl-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="5 8 10 13 15 8"/>
          </svg>
        </div>
        <div class="tl-body">
          <div class="tl-body-inner">
            <p>Diplôme Institutionnel de Nutrition Santé et Micronutrition, délivré par l'<a href="https://www.siin-nutrition.com/fr/" target="_blank">institut SIIN</a>. <br>Formation complète sur 3 ans, de la physiologie aux pathologies, avec études de cas cliniques et mises en pratique.</p>
            <div class="tl-divider"></div>
            <div class="tl-section-label">Spécialités</div>
            <div class="tl-tags">
              <span class="tl-tag tag-sage">Hormono-nutrition</span>
              <span class="tl-tag tag-sage">Gynéco-nutrition</span>
              <span class="tl-tag tag-sage">Nutrition du sport</span>
              <span class="tl-tag tag-sage">Microbiote</span>
              <span class="tl-tag tag-sage">Chrono-nutrition</span>
              <span class="tl-tag tag-sage">Neuro-nutrition</span>
              <span class="tl-tag tag-sage">Compléments alimentaires</span>
              <span class="tl-tag tag-sage">Bilan micronutritionnel</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── ÈRE 3 : ACCOMPAGNEMENT / COACHING ─── -->
  <div class="tl-era-group era-today-group">
    <span class="tl-era-label">Accompagnement / Coaching<span class="tl-era-dates"> · depuis 2023</span></span>

    <!-- Naturopathe spécialisée -->
    <div class="tl-item era-today-item">
      <div class="tl-spine">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-content">
        <div class="tl-header">
          <div class="tl-meta">
            <span class="tl-period">2023 — 2026</span>
            <span class="tl-title">Naturopathe micronutritionniste</span>
          </div>
          <svg class="tl-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="5 8 10 13 15 8"/>
          </svg>
        </div>
        <div class="tl-body">
          <div class="tl-body-inner">
            <p>Pratique en cabinet avec accompagnements individuels intégrant :</p>
            <ul>
              <li>Analyse de la composition corporelle par impédancemétrie multifréquence</li>
              <li>Bilan micronutritionnel et fonctionnel</li>
            </ul>
            <div class="tl-divider"></div>
            <div class="tl-section-label">Profils accompagnés</div>
            <div class="tl-tags">
              <span class="tl-tag tag-gold">Troubles digestifs</span>
              <span class="tl-tag tag-gold">Nutrition du sportif</span>
              <span class="tl-tag tag-gold">Surpoids</span>
              <span class="tl-tag tag-gold">Troubles hormonaux</span>
              <span class="tl-tag tag-gold">Douleurs chroniques</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stratège -->
    <div class="tl-item era-today-item">
      <div class="tl-spine">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-content">
        <div class="tl-header">
          <div class="tl-meta">
            <span class="tl-period">Aujourd'hui</span>
            <span class="tl-title">Stratège Performance & Santé Féminine</span>
          </div>
          <svg class="tl-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="5 8 10 13 15 8"/>
          </svg>
        </div>
        <div class="tl-body">
          <div class="tl-body-inner">
            <p>Accompagnement des femmes sportives d'endurance — Approche scientifique & naturelle</p>
            <div class="tl-divider"></div>
            <div class="tl-section-label">Formation continue & veille scientifique</div>
            <div class="tl-tags">
              <span class="tl-tag tag-gold">Cohérence cardiaque</span>
              <span class="tl-tag tag-gold">Analyse de la VFC</span>
              <span class="tl-tag tag-gold">Santé féminine</span>
              <span class="tl-tag tag-gold">Nutrition du sportif</span>
              <span class="tl-tag tag-gold">Optimisation de la performance</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  .tl-container {
    max-width: 600px; /* === AJUSTE : largeur max timeline === */
    margin: 40px auto 0; /* === AJUSTE : marge haut timeline === */
    position: relative;
    background: transparent; /* === AJUSTE : fond timeline (était: linear-gradient(to bottom, rgba(60, 87, 29, 0.1) 6%, rgba(154, 177, 139, 0.12) 38%, rgba(192, 161, 88, 0.12) 70%)) === */
    border-radius: 12px; /* === AJUSTE : coins arrondis container === */
    padding: 10px 0; /* === AJUSTE : espacement vertical container === */
  }

  /* Connecteur vertical continu derrière toute la timeline */
  .tl-container::before {
    content: '';
    position: absolute;
    left: 45px; /* === AJUSTE : position horizontale connecteur continu (padding groupe 24px + centre spine 22px) === */
    top: 30px; /* === AJUSTE : début du connecteur continu === */
    bottom: 50px; /* === AJUSTE : fin du connecteur continu === */
    width: 3px; /* === AJUSTE : épaisseur connecteur continu === */
    background: linear-gradient(to bottom, #3c571d 6%, #9ab18b 38%, #c0a158 70%); /* === AJUSTE : dégradé connecteur synchro avec les traits horizontaux (6%, 38%, 70%) === */
    z-index: 0;
  }

  /* === GROUPE D'ÈRE === */
  .tl-era-group {
    position: relative;
    padding: 10px 24px 10px; /* === AJUSTE : espacement intérieur groupe === */
    border-radius: 12px; /* === AJUSTE : coins arrondis groupe === */
  }

  .era-science-group {
    background: transparent; /* === fond géré par le container === */
  }

  .era-transition-group {
    background: transparent; /* === fond géré par le container === */
  }

  .era-today-group {
    background: transparent; /* === fond géré par le container === */
  }

  /* === LABEL D'ÈRE (dans le flux, aligné avec le contenu) === */
  .tl-era-label {
    display: block;
    position: relative;
    margin-left: 44px; /* === AJUSTE : aligné avec le bord gauche des cartes dépliables === */
    margin-top: 6px; /* === AJUSTE : marge haute label ère === */
    margin-bottom: 2px; /* === AJUSTE : marge basse label ère === */
    font-size: 10px; /* === AJUSTE : taille label ère === */
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 3px 12px; /* === AJUSTE : espacement intérieur label ère === */
    border-radius: 20px;
    width: fit-content;
    z-index: 2;
  }

  .tl-era-dates {
    font-weight: 400; /* === AJUSTE : dates en poids normal (pas gras) === */
  }

  .tl-era-label::before {
    content: '';
    position: absolute;
    right: 100%; /* === part du bord gauche de l'étiquette === */
    top: 50%;
    transform: translateY(-50%);
    width: 22px; /* === AJUSTE : longueur trait horizontal (44px label margin - 22px spine center) === */
    height: 3px; /* === AJUSTE : épaisseur trait horizontal === */
    border-radius: 2px;
  }

  .era-science-group .tl-era-label::before {
    background: #3c571d; /* === AJUSTE : trait vert foncé === */
  }

  .era-transition-group .tl-era-label::before {
    background: #9ab18b; /* === AJUSTE : trait sauge === */
  }

  .era-today-group .tl-era-label::before {
    background: #c0a158; /* === AJUSTE : trait or === */
  }

  .era-science-group .tl-era-label {
    background: #3c571d; /* === AJUSTE : fond vert foncé opaque === */
    color: #fff;
    border: none;
  }

  .era-transition-group .tl-era-label {
    background: #9ab18b; /* === AJUSTE : fond sauge opaque === */
    color: #fff;
    border: none;
  }

  .era-today-group .tl-era-label {
    background: #c0a158; /* === AJUSTE : fond or opaque === */
    color: #fff;
    border: none;
  }

  /* === ITEM TIMELINE === */
  .tl-item {
    display: flex;
    gap: 10px; /* === AJUSTE : espace entre le dot et le bloc dépliable === */
    position: relative;
  }

  /* === SPINE (ligne + point) === */
  .tl-spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 44px; /* === AJUSTE : largeur colonne spine === */
    flex-shrink: 0;
  }

  .tl-dot {
    width: 36px; /* === AJUSTE : taille du point === */
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 14px;
    z-index: 1;
    transition: transform 0.25s, box-shadow 0.25s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tl-dot svg {
    width: 18px; /* === AJUSTE : taille icône dans le point === */
    height: 18px;
  }

  /* Couleurs points par ère */
  .era-science-item .tl-dot {
    background: #3c571d; /* === AJUSTE : fond vert foncé des points recherche === */
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px rgba(60, 87, 29, 0.2);
    color: #fff;
  }
  .era-transition-item .tl-dot {
    background: var(--color-sage);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px rgba(154, 177, 139, 0.2);
    color: #fff;
  }
  .era-today-item .tl-dot {
    background: var(--color-gold);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px rgba(192, 161, 88, 0.2);
    color: #fff;
  }

  .tl-item.open .tl-dot {
    transform: scale(1.15);
  }

  .tl-item.open .tl-dot {
    box-shadow: none; /* === AJUSTE : pas de halo quand ouvert, juste le rond coloré === */
    border: none; /* === AJUSTE : pas de bordure blanche quand ouvert === */
  }

  .tl-line {
    width: 2px; /* === AJUSTE : épaisseur ligne spine === */
    flex: 1;
    margin-top: 4px;
    min-height: 12px;
  }

  /* Lignes individuelles masquées — le connecteur continu ::before suffit */
  .tl-line { background: transparent !important; }

  /* === EN-TÊTE CLIQUABLE === */
  .tl-content {
    flex: 1;
    padding-bottom: 6px;
  }

  .tl-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    cursor: pointer;
    padding: 14px 20px; /* === AJUSTE : espacement intérieur en-tête === */
    background-color: var(--color-white);
    border-radius: 8px; /* === AJUSTE : coins arrondis === */
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06); /* === AJUSTE : ombre === */
    transition: box-shadow 0.3s, border-color 0.2s;
    user-select: none;
    margin-top: 8px;
  }

  .tl-header:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12); /* === AJUSTE : ombre grise au survol === */
  }

  .tl-item.open .tl-header {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12); /* === AJUSTE : ombre grise quand déplié === */
  }

  /* Header ouvert — bordure gauche épaisse colorée par ère */
  .era-science-item.open .tl-header {
    border-left: 4px solid #3c571d; /* === AJUSTE : épaisseur bordure gauche ouverte === */
    border-radius: 8px 8px 0 0;
    border-bottom-color: transparent;
  }
  .era-transition-item.open .tl-header {
    border-left: 4px solid #9ab18b; /* === AJUSTE : épaisseur bordure gauche ouverte === */
    border-radius: 8px 8px 0 0;
    border-bottom-color: transparent;
  }
  .era-today-item.open .tl-header {
    border-left: 4px solid #c0a158; /* === AJUSTE : épaisseur bordure gauche ouverte === */
    border-radius: 8px 8px 0 0;
    border-bottom-color: transparent;
  }

  .tl-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .tl-period {
    font-size: 11px; /* === AJUSTE : taille période === */
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  /* Couleurs périodes par ère */
  .era-science-item .tl-period    { color: #3c571d; }
  .era-transition-item .tl-period { color: #6b8a5a; }
  .era-today-item .tl-period      { color: var(--color-gold); }

  .tl-title {
    font-size: 16px; /* === AJUSTE : taille titre === */
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.35;
  }


  /* Chevron SVG */
  .tl-chevron {
    width: 18px; /* === AJUSTE : taille chevron === */
    height: 18px;
    flex-shrink: 0;
    color: var(--color-gold);
    transition: transform 0.3s, color 0.2s;
  }

  .tl-item.open .tl-chevron {
    transform: rotate(180deg);
  }

  /* === CONTENU DÉPLIABLE === */
  .tl-body {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s cubic-bezier(0, 1, 0.5, 1), opacity 0.2s ease; /* === AJUSTE : durée animation (cubic-bezier pour fermeture fluide) === */
  }

  .tl-item.open .tl-body {
    max-height: var(--body-height, 500px); /* === AJUSTE : hauteur max dépliée (calculée par JS) === */
    opacity: 1;
  }

  .tl-body-inner {
    padding: 16px 20px 20px; /* === AJUSTE : espacement intérieur contenu === */
    font-size: 15px; /* === AJUSTE : taille texte contenu === */
    color: var(--color-text-light);
    line-height: 1.65;
    background-color: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-top: none;
    border-radius: 0 0 8px 8px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06); /* === AJUSTE : ombre contenu déplié === */
  }

  /* Bordure body-inner par ère quand ouvert — bordure gauche épaisse */
  .era-science-item.open .tl-body-inner    { border-left: 4px solid #3c571d; /* === AJUSTE : bordure gauche body === */ }
  .era-transition-item.open .tl-body-inner { border-left: 4px solid #9ab18b; /* === AJUSTE : bordure gauche body === */ }
  .era-today-item.open .tl-body-inner      { border-left: 4px solid #c0a158; /* === AJUSTE : bordure gauche body === */ }

  .tl-body-inner ul {
    list-style: disc; /* === AJUSTE : puces rondes === */
    padding-left: 20px; /* === AJUSTE : retrait liste === */
    margin: 8px 0 0;
  }

  .tl-body-inner li {
    margin-bottom: 4px; /* === AJUSTE : espace entre items === */
  }

  .tl-body-inner p { margin-bottom: 0; }
  .tl-body-inner p + p { margin-top: 10px; }

  /* Séparateur dans le contenu */
  .tl-divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.08);
    margin: 14px 0; /* === AJUSTE : marge séparateur === */
  }

  /* Label de sous-section */
  .tl-section-label {
    font-size: 10px; /* === AJUSTE : taille label sous-section === */
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 8px;
  }

  /* Tags */
  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px; /* === AJUSTE : espace entre tags === */
    margin-top: 4px;
  }

  .tl-tag {
    font-size: 12px; /* === AJUSTE : taille tag === */
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.03em;
  }

  .tag-sage {
    background: rgba(154, 177, 139, 0.12);
    border: 1px solid rgba(154, 177, 139, 0.3);
    color: #5a7a4a;
  }

  .tag-gold {
    background: rgba(192, 161, 88, 0.1);
    border: 1px solid rgba(192, 161, 88, 0.3);
    color: #a8893e;
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .tl-container {
      max-width: 100%; /* === AJUSTE MOBILE : pleine largeur === */
    }

    .tl-spine {
      width: 36px; /* === AJUSTE MOBILE : largeur spine === */
    }

    .tl-dot {
      width: 30px;
      height: 30px;
    }

    .tl-dot svg {
      width: 15px;
      height: 15px;
    }

    .tl-title {
      font-size: 14px; /* === AJUSTE MOBILE : taille titre === */
    }

    .tl-era-label {
      font-size: 9px; /* === AJUSTE MOBILE : taille label ère === */
      margin-left: 36px; /* === AJUSTE MOBILE : aligné avec le bord gauche des cartes dépliables === */
    }

    .tl-era-label::before {
      width: 18px; /* === AJUSTE MOBILE : longueur trait horizontal (36px label margin - 18px spine center) === */
    }

    .tl-era-dates {
      display: none; /* === masquer les dates en mobile, déjà sur chaque item === */
    }

    .tl-era-group {
      padding-left: 10px; /* === AJUSTE MOBILE : marge gauche groupe === */
      padding-right: 20px; /* === AJUSTE MOBILE : marge droite groupe === */
    }

    .tl-era-label {
      margin-left: 36px; /* === AJUSTE MOBILE : aligné avec le bord gauche des cartes dépliables === */
    }

    /* Repositionner le connecteur continu pour la spine réduite en mobile */
