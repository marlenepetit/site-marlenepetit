</style>

<script>
  document.querySelectorAll('.tl-header').forEach(function(header) {
    header.addEventListener('click', function() {
      var item = this.closest('.tl-item');
      var isOpen = item.classList.contains('open');

      /* Fermer tous les items ouverts */
      document.querySelectorAll('.tl-item.open').forEach(function(el) {
        el.querySelector('.tl-body').style.setProperty('--body-height', '0px');
        el.classList.remove('open');
      });

      /* Ouvrir l'item cliqué si pas déjà ouvert */
      if (!isOpen) {
        var body = item.querySelector('.tl-body');
        var inner = item.querySelector('.tl-body-inner');
        var h = inner.scrollHeight + 10; /* === marge de sécurité pour bordures/padding === */
        body.style.setProperty('--body-height', h + 'px');
        item.classList.add('open');
      }
    });
  });
</script>
